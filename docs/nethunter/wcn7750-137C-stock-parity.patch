+#ifdef WLAN_FEATURE_FAST_SAP_ACS
+static int separate_24g_5g_freq(uint32_t *raw_data, uint32_t raw_data_len,
+				uint32_t *freq_list_24g,
+				uint32_t *freq_list_24g_len,
+				uint32_t *freq_list_5g,
+				uint32_t *freq_list_5g_len)
+{
+	uint32_t ch_index;
+
+	for (ch_index = 0; ch_index < raw_data_len; ch_index++) {
+		if (WLAN_REG_IS_24GHZ_CH_FREQ(raw_data[ch_index])) {
+			freq_list_24g[*freq_list_24g_len] = raw_data[ch_index];
+			(*freq_list_24g_len)++;
+		} else if (WLAN_REG_IS_5GHZ_CH_FREQ(raw_data[ch_index])) {
+			freq_list_5g[*freq_list_5g_len] = raw_data[ch_index];
+			(*freq_list_5g_len)++;
+		}
+	}
+
+	return 0;
+}
+
+static int hdd_get_usable_channel(struct hdd_context *hdd_ctx,
+				  const void *data, uint32_t data_len,
+				  int ch_width, uint32_t *list_usable_2g,
+				  uint32_t *list_usable_2g_count,
+				  uint32_t *list_usable_5g,
+				  uint32_t *list_usable_5g_count)
+{
+	struct get_usable_chan_req_params req_msg = {0};
+	struct get_usable_chan_res_params *res_msg;
+	struct nlattr *tb[QCA_WLAN_VENDOR_ATTR_USABLE_CHANNELS_MAX + 1];
+	int ret;
+	uint32_t count = 0, i;
+	QDF_STATUS status;
+	uint32_t sap_cfg_tmp[NUM_CHANNELS];
+	uint32_t sap_cfg_tmp_count = 0;
+
+	if (QDF_GLOBAL_FTM_MODE == hdd_get_conparam())
+		return -EPERM;
+
+	ret = wlan_hdd_validate_context(hdd_ctx);
+	if (ret)
+		return ret;
+
+	ret = wlan_cfg80211_nla_parse(tb,
+				      QCA_WLAN_VENDOR_ATTR_USABLE_CHANNELS_MAX,
+				      data, data_len,
+				      get_usable_channel_policy);
+	if (ret) {
+		hdd_err("Invalid usable channel attrs");
+		return ret;
+	}
+
+	res_msg = qdf_mem_malloc(NUM_CHANNELS * sizeof(*res_msg));
+	if (!res_msg) {
+		hdd_err("res_msg invalid");
+		return -EINVAL;
+	}
+
+	if (!tb[QCA_WLAN_VENDOR_ATTR_USABLE_CHANNELS_BAND_MASK]) {
+		req_msg.band_mask = BIT(REG_BAND_2G) | BIT(REG_BAND_5G) |
+				    BIT(REG_BAND_6G);
+	} else {
+		req_msg.band_mask =
+			nla_get_u32(tb[QCA_WLAN_VENDOR_ATTR_USABLE_CHANNELS_BAND_MASK]);
+		if (!req_msg.band_mask) {
+			req_msg.band_mask = BIT(REG_BAND_2G) | BIT(REG_BAND_5G) |
+					    BIT(REG_BAND_6G);
+		} else {
+			if (req_msg.band_mask & BIT(NL80211_BAND_2GHZ))
+				req_msg.band_mask |= BIT(REG_BAND_2G);
+			if (req_msg.band_mask & BIT(NL80211_BAND_5GHZ))
+				req_msg.band_mask |= BIT(REG_BAND_5G);
+			if (req_msg.band_mask & BIT(NL80211_BAND_6GHZ))
+				req_msg.band_mask |= BIT(REG_BAND_6G);
+			if (req_msg.band_mask & BIT(NL80211_BAND_60GHZ))
+				hdd_err("band: %d not supported",
+					NL80211_BAND_60GHZ);
+		}
+	}
+
+	if (!tb[QCA_WLAN_VENDOR_ATTR_USABLE_CHANNELS_IFACE_MODE_MASK]) {
+		req_msg.iface_mode_mask = BIT(NL80211_IFTYPE_STATION) |
+					  BIT(NL80211_IFTYPE_AP) |
+					  BIT(NL80211_IFTYPE_P2P_GO) |
+					  BIT(NL80211_IFTYPE_P2P_CLIENT) |
+					  BIT(NL80211_IFTYPE_P2P_DEVICE) |
+					  BIT(NL80211_IFTYPE_NAN);
+	} else {
+		req_msg.iface_mode_mask =
+			nla_get_u32(tb[QCA_WLAN_VENDOR_ATTR_USABLE_CHANNELS_IFACE_MODE_MASK]);
+		if (!req_msg.iface_mode_mask)
+			req_msg.iface_mode_mask =
+				BIT(NL80211_IFTYPE_STATION) |
+				BIT(NL80211_IFTYPE_AP) |
+				BIT(NL80211_IFTYPE_P2P_GO) |
+				BIT(NL80211_IFTYPE_P2P_CLIENT) |
+				BIT(NL80211_IFTYPE_P2P_DEVICE) |
+				BIT(NL80211_IFTYPE_NAN);
+	}
+
+	if (tb[QCA_WLAN_VENDOR_ATTR_USABLE_CHANNELS_FILTER_MASK])
+		req_msg.filter_mask =
+			nla_get_u32(tb[QCA_WLAN_VENDOR_ATTR_USABLE_CHANNELS_FILTER_MASK]);
+
+	status = wlan_reg_get_usable_channel(hdd_ctx->pdev, req_msg, res_msg,
+					     &count, REG_CURRENT_PWR_MODE);
+	if (status != QDF_STATUS_SUCCESS) {
+		hdd_err("get usable channel failed %d", status);
+		ret = -EINVAL;
+		goto free_res;
+	}
+
+	for (i = 0; i < count; i++) {
+		if (!res_msg[i].freq)
+			continue;
+		if (ch_width <= res_msg[i].bw)
+			sap_cfg_tmp[sap_cfg_tmp_count++] = res_msg[i].freq;
+	}
+
+	separate_24g_5g_freq(sap_cfg_tmp, sap_cfg_tmp_count, list_usable_2g,
+			     list_usable_2g_count, list_usable_5g,
+			     list_usable_5g_count);
+
+free_res:
+	qdf_mem_free(res_msg);
+	return ret ? ret : sap_cfg_tmp_count;
+}
+
+static int hdd_set_acs_freq_same_as_wifi(struct hdd_context *hdd_ctx)
+{
+	struct hdd_adapter *adapter, *next_adapter = NULL;
+	struct hdd_station_ctx *sta_ctx;
+	wlan_net_dev_ref_dbgid dbgid = NET_DEV_HOLD_GET_SAP_OPERATING_BAND;
+	struct wlan_hdd_link_info *link_info;
+	uint32_t freq_sta_connected = 0;
+
+	hdd_for_each_adapter_dev_held_safe(hdd_ctx, adapter, next_adapter, dbgid) {
+		hdd_adapter_for_each_active_link_info(adapter, link_info) {
+			if (adapter && adapter->device_mode == QDF_STA_MODE) {
+				sta_ctx = WLAN_HDD_GET_STATION_CTX_PTR(link_info);
+				if (sta_ctx && hdd_is_vdev_in_conn_state(link_info))
+					freq_sta_connected = sta_ctx->conn_info.chan_freq;
+			}
+		}
+		hdd_adapter_dev_put_debug(adapter, dbgid);
+	}
+
+	if ((policy_mgr_is_hw_dbs_capable(hdd_ctx->psoc) &&
+	     WLAN_REG_IS_5GHZ_CH_FREQ(freq_sta_connected)) ||
+	    (!policy_mgr_is_hw_dbs_capable(hdd_ctx->psoc) &&
+	     !policy_mgr_is_hw_sbs_capable(hdd_ctx->psoc)))
+		return freq_sta_connected;
+
+	return 0;
+}
+
+static bool hdd_is_acs_channel_safe_channel(struct hdd_context *hdd_ctx,
+					    int channel_count,
+					    uint32_t *freq_list)
+{
+	uint8_t ch_index;
+
+	for (ch_index = 0; ch_index < channel_count; ch_index++) {
+		if (!policy_mgr_is_safe_channel(hdd_ctx->psoc, freq_list[ch_index]))
+			return false;
+	}
+
+	return true;
+}
+
+static int hdd_update_acs_info(struct hdd_context *hdd_ctx,
+			       struct sap_config *sap_cfg, const void *data,
+			       uint32_t data_len)
+{
+	uint32_t list_sap_cfg_2g_count = 0;
+	uint32_t list_sap_cfg_2g[MAX_CHANNEL] = {0};
+	uint32_t list_sap_cfg_5g_count = 0;
+	uint32_t list_sap_cfg_5g[MAX_CHANNEL] = {0};
+	uint32_t freq_list_usable_2g_count = 0;
+	uint32_t freq_list_usable_2g[NUM_CHANNELS] = {0};
+	uint32_t freq_list_usable_5g_count = 0;
+	uint32_t freq_list_usable_5g[NUM_CHANNELS] = {0};
+	uint32_t i, j;
+	uint32_t freq_list_tmp_count = 0;
+	uint32_t freq_list_tmp[NUM_CHANNELS] = {0};
+	uint32_t freq_tmp_index;
+	uint32_t freq_same_as_wifi;
+	uint32_t pcl_index, ori_freq_index;
+	bool freq_in_pcl = false;
+
+	if (!hdd_ctx) {
+		hdd_err("hdd_ctx is NULL");
+		return -EINVAL;
+	}
+
+	hdd_debug("do fast sap ACS start");
+	freq_same_as_wifi = hdd_set_acs_freq_same_as_wifi(hdd_ctx);
+	if (freq_same_as_wifi) {
+		freq_list_tmp[0] = freq_same_as_wifi;
+		freq_list_tmp_count = 1;
+		goto out;
+	}
+
+	hdd_get_usable_channel(hdd_ctx, data, data_len, sap_cfg->acs_cfg.ch_width,
+			       freq_list_usable_2g,
+			       &freq_list_usable_2g_count,
+			       freq_list_usable_5g,
+			       &freq_list_usable_5g_count);
+
+	separate_24g_5g_freq(sap_cfg->acs_cfg.freq_list,
+			     sap_cfg->acs_cfg.ch_list_count,
+			     list_sap_cfg_2g, &list_sap_cfg_2g_count,
+			     list_sap_cfg_5g, &list_sap_cfg_5g_count);
+
+	for (i = 0; i < freq_list_usable_2g_count; i++) {
+		if (list_sap_cfg_2g_count &&
+		    freq_list_usable_2g[i] > list_sap_cfg_2g[0] &&
+		    freq_list_usable_2g[i] < list_sap_cfg_2g[list_sap_cfg_2g_count - 1])
+			freq_list_tmp[freq_list_tmp_count++] = freq_list_usable_2g[i];
+	}
+
+	for (j = 0; j < freq_list_usable_5g_count; j++) {
+		if (list_sap_cfg_5g_count &&
+		    freq_list_usable_5g[j] >= list_sap_cfg_5g[0] &&
+		    freq_list_usable_5g[j] <= list_sap_cfg_5g[list_sap_cfg_5g_count - 1])
+			freq_list_tmp[freq_list_tmp_count++] = freq_list_usable_5g[j];
+	}
+
+	if (!freq_list_tmp_count) {
+		hdd_debug("fast SAP ACS get null suitable channel");
+		return -EINVAL;
+	}
+
+out:
+	if (!hdd_is_acs_channel_safe_channel(hdd_ctx, freq_list_tmp_count,
+					     freq_list_tmp)) {
+		hdd_debug("No safe channel, do nothing");
+		return -EINVAL;
+	}
+
+	for (ori_freq_index = 0; ori_freq_index < freq_list_tmp_count;
+	     ori_freq_index++) {
+		for (pcl_index = 0; pcl_index < sap_cfg->acs_cfg.pcl_ch_count;
+		     pcl_index++) {
+			if (sap_cfg->acs_cfg.pcl_chan_freq[pcl_index] ==
+			    freq_list_tmp[ori_freq_index]) {
+				freq_in_pcl = true;
+				break;
+			}
+		}
+	}
+
+	if (!freq_in_pcl) {
+		hdd_debug("No suitable channel in PCL, do nothing");
+		return -EINVAL;
+	}
+
+	sap_cfg->acs_cfg.start_ch_freq = freq_list_tmp[0];
+	sap_cfg->acs_cfg.end_ch_freq = freq_list_tmp[freq_list_tmp_count - 1];
+
+	for (freq_tmp_index = 0; freq_tmp_index < sap_cfg->acs_cfg.ch_list_count;
+	     freq_tmp_index++) {
+		if (freq_tmp_index < freq_list_tmp_count)
+			sap_cfg->acs_cfg.freq_list[freq_tmp_index] =
+				freq_list_tmp[freq_tmp_index];
+		else
+			sap_cfg->acs_cfg.freq_list[freq_tmp_index] = 0;
+	}
+
+	sap_cfg->acs_cfg.ch_list_count = freq_list_tmp_count;
+	hdd_nofl_debug("Dump raw FAST ACS chanlist - ");
+	sap_dump_acs_channel(&sap_cfg->acs_cfg);
+
+	return 0;
+}
