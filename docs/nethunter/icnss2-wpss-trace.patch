+		}
 		ret = icnss_call_driver_probe(priv);
 	}
 
@@ -2013,6 +2037,8 @@ static int icnss_driver_event_fw_ready_ind(struct icnss_priv *priv, void *data,
 
 out:
+	icnss_pr_info("konoha_icnss_trace: fw_ready exit ret=%d state=0x%lx\n",
+		      ret, priv->state);
 	return ret;
 }
 
@@ -2026,6 +2052,8 @@ static int icnss_driver_event_fw_init_done(struct icnss_priv *priv, void *data)
 	if (!priv)
 		return -ENODEV;
 
+	icnss_pr_info("konoha_icnss_trace: fw_init_done enter state=0x%lx cold_cal=%d\n",
+		      priv->state, test_bit(ICNSS_COLD_BOOT_CAL, &priv->state));
 	icnss_pr_info("WLAN FW Initialization done: 0x%lx\n", priv->state);
 
 	if (priv->device_id == WCN6750_DEVICE_ID) {
@@ -2039,10 +2067,15 @@ static int icnss_driver_event_fw_init_done(struct icnss_priv *priv, void *data)
 	if (test_bit(ICNSS_COLD_BOOT_CAL, &priv->state)) {
 		mod_timer(&priv->recovery_timer,
 			  jiffies + msecs_to_jiffies(ICNSS_CAL_TIMEOUT));
+		icnss_pr_info("konoha_icnss_trace: fw_init_done send calibration mode\n");
 		ret = wlfw_wlan_mode_send_sync_msg(priv,
 			(enum wlfw_driver_mode_enum_v01)ICNSS_CALIBRATION);
+		icnss_pr_info("konoha_icnss_trace: fw_init_done calibration ret=%d state=0x%lx\n",
+			      ret, priv->state);
 	} else {
+		icnss_pr_info("konoha_icnss_trace: fw_init_done direct fw_ready\n");
 		icnss_driver_event_fw_ready_ind(priv, NULL, false);
 	}
 
diff --git a/platform/icnss2/qmi.c b/platform/icnss2/qmi.c
--- a/platform/icnss2/qmi.c
+++ b/platform/icnss2/qmi.c
