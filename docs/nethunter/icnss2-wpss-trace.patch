-	else
+	} else {
 		ret = wait_for_completion_interruptible(&event->complete);
+	}
 
 	icnss_pr_dbg("Completed event: %s(%d), state: 0x%lx, ret: %d/%d\n",
 		     icnss_driver_event_to_str(type), type, priv->state, ret,
