+	icnss_pr_info("konoha_icnss_trace: done event=%s ret=%d event_ret=%d state=0x%lx\n",
+		      icnss_driver_event_to_str(type), ret, event->ret,
+		      priv->state);
 	spin_lock_irqsave(&priv->event_lock, irq_flags);
 	if (ret == -ERESTARTSYS && event->ret == ICNSS_EVENT_PENDING) {
 		event->sync = false;
@@ -1468,16 +1476,24 @@ static int icnss_call_driver_probe(struct icnss_priv *priv)
 	int ret = 0;
 	int probe_cnt = 0;
 
-	if (!priv->ops || !priv->ops->probe)
+	icnss_pr_info("konoha_icnss_trace: call_driver_probe enter ops=%p probe=%p pdev=%p state=0x%lx\n",
+		      priv->ops, priv->ops ? priv->ops->probe : NULL,
+		      priv->pdev, priv->state);
+	if (!priv->ops || !priv->ops->probe) {
+		icnss_pr_info("konoha_icnss_trace: call_driver_probe no_ops\n");
 		return 0;
+	}
 
-	if (test_bit(ICNSS_DRIVER_PROBED, &priv->state))
+	if (test_bit(ICNSS_DRIVER_PROBED, &priv->state)) {
+		icnss_pr_info("konoha_icnss_trace: call_driver_probe already_probed\n");
 		return -EINVAL;
+	}
 
 	icnss_pr_dbg("Calling driver probe state: 0x%lx\n", priv->state);
 
 	icnss_hw_power_on(priv);
 
 	icnss_block_shutdown(true);
+	icnss_pr_info("konoha_icnss_trace: call_driver_probe loop begin\n");
 	while (probe_cnt < ICNSS_MAX_PROBE_CNT) {
 		ret = priv->ops->probe(&priv->pdev->dev);
 		probe_cnt++;
@@ -1485,6 +1501,8 @@ static int icnss_call_driver_probe(struct icnss_priv *priv)
 			break;
 	}
 	if (ret < 0) {
+		icnss_pr_info("konoha_icnss_trace: call_driver_probe failed ret=%d cnt=%d state=0x%lx\n",
+			      ret, probe_cnt, priv->state);
 		icnss_pr_err("Driver probe failed: %d, state: 0x%lx, probe_cnt: %d\n",
 			     ret, priv->state, probe_cnt);
 		icnss_block_shutdown(false);
@@ -1494,6 +1512,8 @@ static int icnss_call_driver_probe(struct icnss_priv *priv)
 	icnss_block_shutdown(false);
 	set_bit(ICNSS_DRIVER_PROBED, &priv->state);
 
+	icnss_pr_info("konoha_icnss_trace: call_driver_probe success cnt=%d state=0x%lx\n",
+		      probe_cnt, priv->state);
 	return 0;
 
 out:
@@ -1981,6 +2001,8 @@ static int icnss_driver_event_fw_ready_ind(struct icnss_priv *priv, void *data,
 	if (!priv)
 		return -ENODEV;
 
+	icnss_pr_info("konoha_icnss_trace: fw_ready enter cold=%d state=0x%lx pdev=%p ops=%p\n",
+		      cold_boot, priv->state, priv->pdev, priv->ops);
 	del_timer(&priv->recovery_timer);
 	set_bit(ICNSS_FW_READY, &priv->state);
 	clear_bit(ICNSS_MODE_ON, &priv->state);
@@ -2004,8 +2026,10 @@ static int icnss_driver_event_fw_ready_ind(struct icnss_priv *priv, void *data,
 
 	if (test_bit(ICNSS_PD_RESTART, &priv->state)) {
 		ret = icnss_pd_restart_complete(priv);
 	} else {
-		if (priv->wpss_supported)
+		if (priv->wpss_supported) {
+			icnss_pr_info("konoha_icnss_trace: fw_ready setup_dms_mac begin\n");
