 	ret = qmi_txn_wait(&txn,
 			   priv->ctrl_params.qmi_timeout +
 			   msecs_to_jiffies(priv->wlan_en_delay_ms));
+	icnss_pr_info("konoha_icnss_trace: mode_req wait ret=%d result=%d error=%d state=0x%lx\n",
+		      ret, resp->resp.result, resp->resp.error, priv->state);
 	if (ret < 0) {
 		icnss_qmi_fatal_err("Mode resp wait failed with ret %d\n", ret);
 		goto out;
