 	if (!test_bit(ICNSS_MODE_ON, &priv->state) &&
 	    mode == QMI_WLFW_OFF_V01)
 		return 0;
 
+	icnss_pr_info("konoha_icnss_trace: mode_req enter state=0x%lx mode=%d timeout=%lu delay=%d\n",
+		      priv->state, mode, priv->ctrl_params.qmi_timeout, priv->wlan_en_delay_ms);
 	icnss_pr_info("Sending Mode request, state: 0x%lx, mode: %d\n",
 		     priv->state, mode);
 
@@ -1571,6 +1573,8 @@ int wlfw_wlan_mode_send_sync_msg(struct icnss_priv *priv,
 	ret = qmi_txn_init(&priv->qmi, &txn,
 			   wlfw_wlan_mode_resp_msg_v01_ei, resp);
 	if (ret < 0) {
+		icnss_pr_info("konoha_icnss_trace: mode_req txn_init ret=%d\n",
