 		icnss_qmi_fatal_err("Fail to init txn for Mode resp %d\n", ret);
 		goto out;
 	}
@@ -1580,12 +1584,17 @@ int wlfw_wlan_mode_send_sync_msg(struct icnss_priv *priv,
 			       WLFW_WLAN_MODE_REQ_MSG_V01_MAX_MSG_LEN,
 			       wlfw_wlan_mode_req_msg_v01_ei, req);
 	if (ret < 0) {
+		icnss_pr_info("konoha_icnss_trace: mode_req send ret=%d\n", ret);
